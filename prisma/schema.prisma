datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Corporation {
  id           String   @id @default(uuid())
  name         String
  subdomain    String?  @unique
  subscription String   @default("FREE")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
  orgGoals     OrgGoal[]
}

model User {
  id               String           @id @default(uuid())
  staffId          String           @unique
  email            String           @unique
  fullName         String
  role             String           // ADMIN, MANAGER, STAFF_CAREGIVER 等
  gradeLevel       Int              @default(1)
  department       String
  birthday         DateTime?
  yearsOfService   Int              @default(0)
  experienceYears  Int              @default(0)
  welfarePoints    Int              @default(0)
  isActive         Boolean          @default(true)
  mustChangePassword Boolean        @default(true)
  
  corporationId    String
  corporation      Corporation      @relation(fields: [corporationId], references: [id])

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  evaluations      Evaluation[]     @relation("EmployeeEvals")
  evaluatorEvals   Evaluation[]     @relation("EvaluatorEvals")
  givenBonuses     PeerBonus[]      @relation("BonusSender")
  receivedBonuses  PeerBonus[]      @relation("BonusReceiver")
  incidents        IncidentReport[]
  goals            Goal[]
  healthLogs       HealthLog[]
  trainingRecords  TrainingRecord[]
  oneOnOneNotes    OneOnOneNote[]   @relation("EmployeeNotes")
  conductedMeetings OneOnOneNote[]  @relation("ManagerNotes")
  createdOrgGoals  OrgGoal[]

  @@index([corporationId])
}

model OrgGoal {
  id           String       @id @default(uuid())
  corporationId String
  corporation   Corporation  @relation(fields: [corporationId], references: [id])
  level        String       // MISSION, CORPORATE, DEPARTMENT
  title        String
  description  String
  department   String?      
  periodKey    String?      
  parentId     String?
  parent       OrgGoal?     @relation("OrgGoalHierarchy", fields: [parentId], references: [id])
  children     OrgGoal[]    @relation("OrgGoalHierarchy")
  createdById  String
  createdBy    User         @relation(fields: [createdById], references: [id])
  goals        Goal[]       
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([corporationId])
}

model Evaluation {
  id               String     @id @default(uuid())
  corporationId    String
  employeeId       String
  employee         User       @relation("EmployeeEvals", fields: [employeeId], references: [id])
  evaluatorId      String
  evaluator        User       @relation("EvaluatorEvals", fields: [evaluatorId], references: [id])
  periodKey        String
  status           String     @default("DRAFT") // DRAFT, SELF_SUBMITTED 等
  achievementScore Float      @default(0.0)
  sentimentScore   Float      @default(0.0)
  competencyScore  Float      @default(0.0)
  totalScore       Float      @default(0.0)
  finalGrade       String?
  aiSummaryText    String?
  updatedAt        DateTime   @updatedAt

  @@index([corporationId])
  @@index([employeeId])
}

model Goal {
  id               String    @id @default(uuid())
  corporationId    String
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  periodKey        String
  title            String
  targetValue      Float
  currentValue     Float     @default(0.0)
  unit             String
  isAchieved       Boolean   @default(false)
  parentOrgGoalId  String?                    
  parentOrgGoal    OrgGoal?  @relation(fields: [parentOrgGoalId], references: [id])
  createdAt        DateTime  @default(now())

  @@index([corporationId])
}

model PeerBonus {
  id               String   @id @default(uuid())
  corporationId    String
  senderId         String
  sender           User     @relation("BonusSender", fields: [senderId], references: [id])
  receiverId       String
  receiver         User     @relation("BonusReceiver", fields: [receiverId], references: [id])
  points           Int      @default(5)
  tag              String
  message          String
  createdAt        DateTime @default(now())

  @@index([corporationId])
}

model IncidentReport {
  id                String       @id @default(uuid())
  corporationId     String
  reporterId        String
  reporter          User         @relation(fields: [reporterId], references: [id])
  type              String       // NEAR_MISS, ACCIDENT, IMPROVEMENT_IDEA
  description       String
  preventionIdea    String?
  aiEvaluatedPoints Int          @default(0)
  createdAt         DateTime     @default(now())

  @@index([corporationId])
}

model HealthLog {
  id               String   @id @default(uuid())
  corporationId    String
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  activityType     String
  value            Int
  earnedPoints     Int      @default(0)
  proofUrl         String?
  loggedAt         DateTime @default(now())

  @@index([corporationId])
}

model OneOnOneNote {
  id               String   @id @default(uuid())
  corporationId    String
  employeeId       String
  employee         User     @relation("EmployeeNotes", fields: [employeeId], references: [id])
  managerId        String
  manager          User     @relation("ManagerNotes", fields: [managerId], references: [id])
  content          String
  aiActionItems    String?
  meetingDate      DateTime
  employeePoints   Int      @default(5)  
  managerPoints    Int      @default(3)  
  pointsGranted    Boolean  @default(false) 
  createdAt        DateTime @default(now())

  @@index([corporationId])
}

model TrainingRecord {
  id               String       @id @default(uuid())
  corporationId    String
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  title            String
  type             String       // OJT, OFF_JT, BOOK
  date             DateTime
  hours            Float
  reportContent    String?
  earnedPoints     Int          @default(5)
  pointsGranted    Boolean      @default(false)
  imageUrl         String?      
  createdAt        DateTime     @default(now())

  @@index([corporationId])
}

