datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  STAFF_CAREGIVER
  STAFF_NURSE
  STAFF_SOCIAL_WORKER
  STAFF_OFFICE
  STAFF_NUTRITIONIST
}

enum EvalStatus {
  DRAFT
  SELF_SUBMITTED
  MANAGER_REVIEWED
  FINALIZED
}

enum IncidentType {
  NEAR_MISS
  ACCIDENT
  IMPROVEMENT_IDEA
}

enum TrainingType {
  OJT
  OFF_JT
}

enum OrgGoalLevel {
  MISSION      // 法人理念（恒久的）
  CORPORATE    // 法人目標（年度）
  DEPARTMENT   // 部署目標（年度・部署別）
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  fullName         String
  role             Role
  gradeLevel       Int              @default(1)
  department       String
  welfarePoints    Int              @default(0)
  isActive         Boolean          @default(true)  // アカウント有効フラグ
  mustChangePassword Boolean        @default(true)  // 初回ログイン時パスワード変更フラグ
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  evaluations      Evaluation[]     @relation("EmployeeEvals")
  evaluatorEvals   Evaluation[]     @relation("EvaluatorEvals")
  givenBonuses     PeerBonus[]      @relation("BonusSender")
  receivedBonuses  PeerBonus[]      @relation("BonusReceiver")
  incidents        IncidentReport[]
  goals            Goal[]
  healthLogs       HealthLog[]
  trainingRecords  TrainingRecord[]
  oneOnOneNotes    OneOnOneNote[]   @relation("EmployeeNotes")
  conductedMeetings OneOnOneNote[]  @relation("ManagerNotes")
  createdOrgGoals  OrgGoal[]
}

model OrgGoal {
  id           String       @id @default(uuid())
  level        OrgGoalLevel
  title        String
  description  String
  department   String?      // 部署目標の場合に使用
  periodKey    String?      // "2026-H1" など（MISSIONはnull）
  parentId     String?
  parent       OrgGoal?     @relation("OrgGoalHierarchy", fields: [parentId], references: [id])
  children     OrgGoal[]    @relation("OrgGoalHierarchy")
  createdById  String
  createdBy    User         @relation(fields: [createdById], references: [id])
  goals        Goal[]       // この組織目標に紐づく個人目標
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Evaluation {
  id               String     @id @default(uuid())
  employeeId       String
  employee         User       @relation("EmployeeEvals", fields: [employeeId], references: [id])
  evaluatorId      String
  evaluator        User       @relation("EvaluatorEvals", fields: [evaluatorId], references: [id])
  periodKey        String
  status           EvalStatus @default(DRAFT)
  achievementScore Float      @default(0.0)
  sentimentScore   Float      @default(0.0)
  competencyScore  Float      @default(0.0)
  totalScore       Float      @default(0.0)
  finalGrade       String?
  aiSummaryText    String?
  updatedAt        DateTime   @updatedAt
}

model Goal {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  periodKey        String
  title            String
  targetValue      Float
  currentValue     Float     @default(0.0)
  unit             String
  isAchieved       Boolean   @default(false)
  parentOrgGoalId  String?                    // 上位の組織目標と連携
  parentOrgGoal    OrgGoal?  @relation(fields: [parentOrgGoalId], references: [id])
  createdAt        DateTime  @default(now())
}

model PeerBonus {
  id               String   @id @default(uuid())
  senderId         String
  sender           User     @relation("BonusSender", fields: [senderId], references: [id])
  receiverId       String
  receiver         User     @relation("BonusReceiver", fields: [receiverId], references: [id])
  points           Int      @default(5)
  tag              String
  message          String
  createdAt        DateTime @default(now())
}

model IncidentReport {
  id                String       @id @default(uuid())
  reporterId        String
  reporter          User         @relation(fields: [reporterId], references: [id])
  type              IncidentType
  description       String
  preventionIdea    String?
  aiEvaluatedPoints Int          @default(0)
  createdAt         DateTime     @default(now())
}

model HealthLog {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  activityType     String
  value            Int
  earnedPoints     Int      @default(0)
  proofUrl         String?
  loggedAt         DateTime @default(now())
}

model OneOnOneNote {
  id               String   @id @default(uuid())
  employeeId       String
  employee         User     @relation("EmployeeNotes", fields: [employeeId], references: [id])
  managerId        String
  manager          User     @relation("ManagerNotes", fields: [managerId], references: [id])
  content          String
  aiActionItems    String?
  meetingDate      DateTime
  employeePoints   Int      @default(5)  // 受講者へのポイント
  managerPoints    Int      @default(3)  // 実施者へのポイント
  pointsGranted    Boolean  @default(false) // ポイント付与済みフラグ（二重付与防止）
  createdAt        DateTime @default(now())
}

model TrainingRecord {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  title            String
  type             TrainingType
  date             DateTime
  hours            Float
  reportContent    String?
  earnedPoints     Int          @default(5)
  pointsGranted    Boolean      @default(false)
  createdAt        DateTime     @default(now())
}
